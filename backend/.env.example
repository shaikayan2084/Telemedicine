# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/telemedicine

# JWT
JWT_SECRET=your_super_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# AES-256 Encryption (PHI Fields)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AES_IV=your_16_byte_hex_iv_here

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL (CORS)
CLIENT_URL=http://localhost:3000

# Signaling Server
SIGNALING_SERVER_URL=http://localhost:4000
